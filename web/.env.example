# Copy to .env.local for local development (never commit secrets).

# When you move off SQLite to a host (Neon, Supabase, Vercel Postgres), set this
# in Vercel → Project → Settings → Environment Variables for Production/Preview.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Optional: canonical site URL for absolute links (invites, ICS) in production
# NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
