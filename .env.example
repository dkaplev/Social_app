# Copy to .env.local for local development (never commit secrets).

# PostgreSQL (Neon, Supabase, Vercel Postgres, local Docker, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

