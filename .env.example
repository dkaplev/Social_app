# Copy to .env.local for local development (never commit secrets).

# SQLite (Phase 1 local). Vercel/serverless: switch provider in prisma/schema.prisma + use Postgres URL.
DATABASE_URL="file:./dev.db"

# Later (Neon / Supabase / Vercel Postgres):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Optional: canonical site URL for absolute links (invites, ICS) in production
# NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
